  "keyFeatures": [
    "Domain-specific language for LLM prompts",
    "Type-safe structured outputs with streaming support",
    "Multi-language support (Python, TypeScript, Ruby, Go, Rust)",
    "Built-in IDE support with VSCode playground",
    "Automatic code generation",
    "Retry policies and fallback strategies",
    "Schema-aligned parsing (SAP) for reliable outputs",
    "Testing framework for prompts",
    "Support for 100+ LLM providers",
    "Multimodal support (images, audio, video)"
  ],
  "publicApiSurface": [
    "function - Define LLM prompts as functions",
    "class - Define output schemas",
    "enum - Define enumeration types",
    "client<llm> - Configure LLM providers",
    "test - Write test cases for functions",
    "template_string - Reusable prompt snippets",
    "baml-cli init - Initialize a BAML project",
    "baml-cli generate - Generate language-specific client code",
    "baml-cli test - Run test cases",
    "baml-cli dev - Start development server with playground",
    "b.FunctionName() - Call BAML functions from Python/TypeScript/etc",
    "b.stream.FunctionName() - Stream responses",
    "TypeBuilder - Build types dynamically at runtime",
    "ClientRegistry - Register clients dynamically",
    "Collector - Track usage metrics and debug information"
  ]
}
